@prefix : <http://smart.uliege.be/prov-extension#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://smart.uliege.be/prov-extension#> .

<http://smart.uliege.be/prov-extension#> rdf:type owl:Ontology ;
                                          owl:versionIRI <http://smart.uliege.be/prov-extension#> ;
                                          owl:imports <http://www.w3.org/ns/prov-o-20130430> .

#################################################################
#    Annotation properties
#################################################################

###  http://smart.uliege.be/prov-extension#activityType
:activityType rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://smart.uliege.be/prov-extension#succeeds
:succeeds rdf:type owl:ObjectProperty ,
                   owl:TransitiveProperty ;
          rdfs:domain <http://www.w3.org/ns/prov#SoftwareAgent> ;
          rdfs:range <http://www.w3.org/ns/prov#SoftwareAgent> .


#################################################################
#    Data properties
#################################################################

###  http://smart.uliege.be/prov-extension#correctResponses
:correctResponses rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :hasNumber .


###  http://smart.uliege.be/prov-extension#grade
:grade rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf <http://www.w3.org/ns/prov#value> ;
       rdfs:domain :Result ;
       rdfs:range xsd:float ;
       rdfs:comment "La note de l'étudiant. La note minimale est 0, la note maximale est 20."@fr .


###  http://smart.uliege.be/prov-extension#hasNumber
:hasNumber rdf:type owl:DatatypeProperty ;
           rdfs:domain :Result ;
           rdfs:range xsd:integer .


###  http://smart.uliege.be/prov-extension#incorrectResponses
:incorrectResponses rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :hasNumber .


###  http://smart.uliege.be/prov-extension#numberOfQuestions
:numberOfQuestions rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain :Survey ;
                   rdfs:range xsd:int ;
                   rdfs:comment "Number of questions asked in a Survey"@en .


###  http://smart.uliege.be/prov-extension#omissions
:omissions rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :hasNumber .


###  http://smart.uliege.be/prov-extension#position
:position rdf:type owl:DatatypeProperty ;
          rdfs:domain :Result ;
          rdfs:range xsd:integer ;
          rdfs:comment "La position de l'étudiant vis à vis de la classe en fonction de sa note"@fr .


###  http://smart.uliege.be/prov-extension#softwareName
:softwareName rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain <http://www.w3.org/ns/prov#SoftwareAgent> ;
              rdfs:range xsd:string .


###  http://smart.uliege.be/prov-extension#succeeds
:succeeds rdf:type owl:DatatypeProperty .


###  http://smart.uliege.be/prov-extension#success
:success rdf:type owl:DatatypeProperty ;
         rdfs:domain :GlobalResult ;
         rdfs:range xsd:boolean ;
         rdfs:comment "Quand un étudiant a une note > 10" .


###  http://smart.uliege.be/prov-extension#successCount
:successCount rdf:type owl:DatatypeProperty ;
              rdfs:domain :Feedback ;
              rdfs:range xsd:integer ;
              rdfs:comment "The number of student who had a grade > 10"@en .


###  http://smart.uliege.be/prov-extension#typeOfMood
:typeOfMood rdf:type owl:DatatypeProperty ;
            rdfs:domain :Mood .


###  http://smart.uliege.be/prov-extension#version
:version rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain <http://www.w3.org/ns/prov#SoftwareAgent> ;
         rdfs:range xsd:string ;
         rdfs:comment "Version of the software"@en .


#################################################################
#    Classes
#################################################################

###  http://smart.uliege.be/prov-extension#Access
:Access rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
        rdfs:comment "Indicates that the actor has accessed the object. For instance, a person accessing a room, or accessing a file."@en ;
        rdfs:seeAlso "http://activitystrea.ms/schema/1.0/Access"@en .


###  http://smart.uliege.be/prov-extension#Acknowledge
:Acknowledge rdf:type owl:Class ;
             rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
             rdfs:comment "Indicates that the actor has acknowledged the object. This effectively signals that the actor is aware of the object's existence."@en ;
             rdfs:seeAlso "http://activitystrea.ms/schema/1.0/acknowledge" .


###  http://smart.uliege.be/prov-extension#Answer
:Answer rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
        rdfs:comment "Reponse à une question"@fr .


###  http://smart.uliege.be/prov-extension#Completed
:Completed rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
           rdfs:comment "l'acteur a terminé l'objet (Test,Survey) associé. Eventuellement un élément 'Result' est associé au statement"@fr .


###  http://smart.uliege.be/prov-extension#Enrolled
:Enrolled rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
          rdfs:comment "L'utilisateur a accepté les condition d'utilisation du service."@fr ,
                       "To put yourself or someone else on an official list for an activity or for membership in a group, or to accept someone in such a list."@en ;
          rdfs:isDefinedBy "Cambridge dictionary"@en ;
          rdfs:seeAlso "http://www.uliege.be/smart/xAPITerms/verbs/enrolled" .


###  http://smart.uliege.be/prov-extension#Feedback
:Feedback rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Collection> ;
          rdfs:comment "Un Feedback SMART"@fr ;
          rdfs:label "Feedback" ;
          rdfs:seeAlso "http://smart.uliege.be/ulla/feedback" .


###  http://smart.uliege.be/prov-extension#GlobalResult
:GlobalResult rdf:type owl:Class ;
              rdfs:subClassOf :Result ;
              rdfs:comment "Global result for an evaluation"@en .


###  http://smart.uliege.be/prov-extension#Instructor
:Instructor rdf:type owl:Class ;
            rdfs:subClassOf <http://www.w3.org/ns/prov#Person> .


###  http://smart.uliege.be/prov-extension#Launch
:Launch rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> .


###  http://smart.uliege.be/prov-extension#LoggedIn
:LoggedIn rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
          rdfs:comment "L'utilisateur s'est connecté à l'application"@fr ;
          rdfs:seeAlso "http://www.uliege.be/smart/xAPITerms/verbs/loggedin" .


###  http://smart.uliege.be/prov-extension#LoggedOut
:LoggedOut rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
           rdfs:comment "L'utilisateur s'est déconnecté et/ou a cloturé sa session dans l'application"@fr .


###  http://smart.uliege.be/prov-extension#Message
:Message rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
         rdfs:comment "Un message à destination des étudiants"@fr ;
         rdfs:label "Message" ;
         rdfs:seeAlso "http://smart.uliege.be/ulla/message" .


###  http://smart.uliege.be/prov-extension#Mood
:Mood rdf:type owl:Class ;
      rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
      rdfs:comment "Un objet dédié aux émotions"@fr ;
      rdfs:seeAlso "http://smart.uliege.be/ulla/moods" .


###  http://smart.uliege.be/prov-extension#PartialResult
:PartialResult rdf:type owl:Class ;
               rdfs:subClassOf :Result ;
               rdfs:comment "Result for a part of an evaluation."@en .


###  http://smart.uliege.be/prov-extension#Provide
:Provide rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
         rdfs:comment "L'acteur à répondu à la question référencée par l'object associé. Le statement devra donc contenir un élément 'Result'."@fr ,
                      "When the actor gives an Answer"@en .


###  http://smart.uliege.be/prov-extension#Received
:Received rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
          rdfs:comment "l'acteur a reçu un élément (Survey, Feeback, Message, ...) associé."@fr .


###  http://smart.uliege.be/prov-extension#Result
:Result rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
        rdfs:comment "Un Feedback SMART pour une partie de test"@fr ;
        rdfs:seeAlso "http://smart.uliege.be/ulla/feedback/part" .


###  http://smart.uliege.be/prov-extension#Student
:Student rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/ns/prov#Person> .


###  http://smart.uliege.be/prov-extension#Survey
:Survey rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Collection> ;
        rdfs:comment "Une enquête à caractère pédagogique orientée LA"@fr ;
        rdfs:seeAlso "http://id.tincanapi.com/activitytype/survey" .


###  http://smart.uliege.be/prov-extension#SurveyQuestion
:SurveyQuestion rdf:type owl:Class ;
                rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                rdfs:comment "Une question associée à une enquête à caractère pédagogique orientée LA"@fr .


###  http://smart.uliege.be/prov-extension#Update
:Update rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
        rdfs:comment "The \"update\" verb indicates that the actor has modified the object. Implementors SHOULD use verbs such as \"post\" where the actor is adding new items to a collection or similar. Update is reserved for modifications to existing object or data such as changing a user's profile information."@en ;
        rdfs:seeAlso <http://activitystrea.ms/schema/1.0/update> .


###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Collection
<http://www.w3.org/ns/prov#Collection> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Person
<http://www.w3.org/ns/prov#Person> rdf:type owl:Class .


