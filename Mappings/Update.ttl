@prefix rml: <http://w3id.org/rml/> .
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix ext: <http://smart.uliege.be/prov-extension#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


<http://example.com/base/#DrillSource> a d2rq:Database ;
    d2rq:jdbcDSN "jdbc:drill:drillbit=localhost" ;
    d2rq:jdbcDriver "org.apache.drill.jdbc.Driver" ;
    d2rq:username "" ;
    d2rq:password "" .

<#DrillQueryMood>
    rml:source <http://example.com/base/#DrillSource> ;
    rml:referenceFormulation rml:SQL2008Query ;
    rml:iterator """
        SELECT 
            t2.id,
            t2.actor_name,
            t2.mood.value.mood_id AS mood_id,
            t2.mood.value.intensity AS intensity,
            t2.ts AS timestampe
        FROM (
            SELECT 
                t1.flatdata.id AS id,
                t1.flatdata.actor.account.name AS actor_name,
                t1.flatdata.`timestamp` AS ts,
                FLATTEN(KVGEN(t1.flatdata.`object`.`definition`.`extensions`)) AS mood
            FROM (
                SELECT FLATTEN(statements) AS flatdata 
                FROM dfs.statements.`*.json`
            ) t1
        ) t2
        WHERE t2.mood.value.mood_id IS NOT NULL
    """ .

# ===============================
# TriplesMap : Student
# ===============================
<#TriplesMapStudent> a rml:TriplesMap ;
    rml:logicalSource <#DrillQueryMood> ;

    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/student/{actor_name}" ;
        rml:class ext:Student
    ] ;

    rml:predicateObjectMap [
        rml:predicate foaf:name ;
        rml:objectMap [ rml:reference "actor_name" ]
    ] .

# ===============================
# TriplesMap : Mood
# ===============================
<#TriplesMapMood> a rml:TriplesMap ;
    rml:logicalSource <#DrillQueryMood> ;

    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/mood/{id}" ;
        rml:class ext:Mood
    ] ;

    rml:predicateObjectMap [
        rml:predicate ext:typeOfMood ;
        rml:objectMap [ rml:reference "mood_id" ]
    ] ;

    rml:predicateObjectMap [
        rml:predicate prov:value ;
        rml:objectMap [ rml:reference "intensity" ; 
                        rml:datatype xsd:float ]
    ] ;

    rml:predicateObjectMap [
        rml:predicate prov:wasAttributedTo ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/student/{actor_name}"
        ]
    ] .
    

# ===============================
# TriplesMap : Update
# ===============================
<#TriplesMapUpdate> a rml:TriplesMap ;
    rml:logicalSource <#DrillQueryMood> ;

    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/update/{id}" ;
        rml:class ext:Update
    ] ;

    rml:predicateObjectMap [
        rml:predicate prov:endedAtTime ;
        rml:objectMap [ rml:reference "timestampe"; rml:datatype xsd:dateTime ]
    ] ;

    rml:predicateObjectMap [
        rml:predicate prov:wasAssociatedWith ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/student/{actor_name}"
        ]
    ] ;

    rml:predicateObjectMap [
        rml:predicate prov:used ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/mood/{id}"
        ]
    ] .