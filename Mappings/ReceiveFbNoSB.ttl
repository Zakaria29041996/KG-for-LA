@prefix rml: <http://w3id.org/rml/> .
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#> .
@prefix ext: <http://smart.uliege.be/prov-extension#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <https://schema.org/> .

<http://example.com/base/#DrillSource>  a d2rq:Database ;
  d2rq:jdbcDSN "jdbc:drill:drillbit=localhost" ;  
  d2rq:jdbcDriver "org.apache.drill.jdbc.Driver" ;
  d2rq:username "" ;
  d2rq:password "" .


<#TriplesMapVerbObject> 
    rml:source <http://example.com/base/#DrillSource> ;
    rml:referenceFormulation rml:SQL2008Query ;
    rml:iterator """
    SELECT 
        -- champs de t1 répercutés
        t3.id,
        t3.student_name,
        t3.ts,
        t3.object_id,
        t3.FB_id,
        t3.title,
        t3.description,
        t3.SC          AS SuccessCount,

        -- instructeur
        t3.instructor_name,
        t3.instructor_id,

        t3.PositionG   AS GPosition,
        t3.score,
        t3.success,

        -- champs enfant
        t3.child.id                      AS child_id,
        t3.child.scores                  AS Child_score,
        t3.child.content.`position`      AS PositionChild
    FROM (
        SELECT 
            t2.id,
            t2.student_name,
            t2.student_homepage,
            t2.ts,
            t2.object_id,
            t2.FB_id,
            t2.title,
            t2.description,
            t2.score,
            t2.success,

            t2.instructor_name,
            t2.instructor_id,

            t2.surveymap.value.data.`position`    AS PositionG,
            t2.surveymap.value.data.`success_count` AS SC,

            FLATTEN(t2.surveymap.value.children) AS child
        FROM (
            SELECT 
                -- extraction t1
                t1.flatdata.id                                  AS id,
                t1.flatdata.actor.account.name                  AS student_name,
                t1.flatdata.actor.account.homePage              AS student_homepage,
                t1.flatdata.`timestamp`                         AS ts,
                t1.flatdata.`object`.id                         AS object_id,
                SPLIT(t1.flatdata.`object`.id, '/')[5]          AS FB_id,
                t1.flatdata.object.definition.name.`fr-FR`      AS title,
                t1.flatdata.object.definition.description.`fr-FR` AS description,
                t1.flatdata.result.score.raw                    AS score,
                t1.flatdata.result.success                      AS success,


                t1.flatdata.context.instructor.name            AS instructor_name,
                t1.flatdata.context.instructor.account.name    AS instructor_id,


                FLATTEN(KVGEN(t1.flatdata.result.extensions))  AS surveymap
            FROM (
                SELECT FLATTEN(statements) AS flatdata 
                FROM dfs.statements.`*.json`
            ) t1
            WHERE 
                t1.flatdata.`verb`.id = 'http://activitystrea.ms/schema/1.0/receive'
                AND t1.flatdata.`object`.definition.`type` = 'http://smart.uliege.be/ulla/feedback'
        ) t2
        WHERE 
            t2.surveymap.value.`data`.position IS NOT NULL
            AND t2.surveymap.value.children.id IS NOT NULL
    ) t3
    WHERE t3.child.content.`score_bar`[0].value IS NULL

    """ ;
    .

# ===============================
# TriplesMap : Student
# ===============================
<#TriplesMapStudent> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/student/{student_name}" ;
        rml:class ext:Student
    ] ;
    rml:predicateObjectMap [
        rml:predicate foaf:name ;
        rml:objectMap [ rml:reference "student_name" ]
    ] .

# ===============================
# TriplesMap : receive (Activity)
# ===============================

<#TriplesMapReceiveActivity> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/receive/{id}" ;
        rml:class ext:Received
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:startedAtTime ;
        rml:objectMap [ rml:reference "ts" ; rml:datatype xsd:dateTime ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:wasAssociatedWith ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/student/{student_name}" ;
        ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:used ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/feedback/{FB_id}" ;
        ]
    ] .

# ===============================
# TriplesMap : Feedback (entity)
# ===============================
<#TriplesMapFeedback> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/feedback/{FB_id}" ;
        rml:class ext:Feedback
    ] ;
    rml:predicateObjectMap [
        rml:predicate schema:name ;
        rml:objectMap [ rml:reference "title" ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate schema:description ;
        rml:objectMap [ rml:reference "description" ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate ext:successCount ; 
        rml:objectMap [ rml:reference "SuccessCount" ; rml:datatype xsd:integer ]
    ] ;

    rml:predicateObjectMap [
        rml:predicate prov:wasAttributedTo ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/student/{student_name}"
        ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:wasAttributedTo ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/instructor/{instructor_id}"
        ]
    ] ;

    rml:predicateObjectMap [
        rml:predicate prov:hadMember ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/result/{student_name}/{FB_id}/{child_id}"
        ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:hadMember ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/result/{student_name}/{FB_id}"
        ]
    ] .


# ===============================
# TriplesMap : Instructor
# ===============================

<#TriplesMapInstructor> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/instructor/{instructor_id}" ;
        rml:class ext:Instructor
    ] ;
    rml:predicateObjectMap [
        rml:predicate foaf:name ;
        rml:objectMap [ rml:reference "instructor_name" ]
    ] .

# ===============================
# TriplesMap : GlobalResult
# ===============================
<#TriplesMapGlobalResult> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/result/{student_name}/{FB_id}" ;
        rml:class ext:GlobalResult ;
    ] ;
    rml:predicateObjectMap [
        rml:predicate ext:success;
        rml:objectMap [
            rml:reference "success" ;
            rml:datatype xsd:boolean ;
        ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate ext:grade;
        rml:objectMap [
            rml:reference "score" ;
            rml:datatype xsd:float ;
        ]
    ] ;

    rml:predicateObjectMap [
        rml:predicate prov:wasAttributedTo ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/student/{student_name}"
        ]
    ] ;

    rml:predicateObjectMap [
        rml:predicate ext:position;
        rml:objectMap [
            rml:reference "GPosition" ;
            rml:datatype xsd:integer ;
        ]
    ] .

# ===============================
# TriplesMap : PartialResult
# ===============================
<#TriplesMapPartialResult> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/result/{student_name}/{FB_id}/{child_id}" ;
        rml:class ext:PartialResult ;
    ] ;
    rml:predicateObjectMap [
        rml:predicate schema:identifier ;
        rml:objectMap [
            rml:reference "child_id" ;
            rml:datatype xsd:integer ; ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate ext:grade ;
        rml:objectMap [
            rml:reference "Child_score" ;
            rml:datatype xsd:float ;
        ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate ext:position ;
        rml:objectMap [
            rml:reference "PositionChild" ;
            rml:datatype xsd:integer ;
        ]
    ] ;


    rml:predicateObjectMap [
        rml:predicate prov:wasAttributedTo ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/student/{student_name}"
        ]
    ] .
    