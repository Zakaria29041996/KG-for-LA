@prefix rml: <http://w3id.org/rml/> .
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#> .
@prefix ext: <http://smart.uliege.be/prov-extension#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <https://schema.org/> .

<http://example.com/base/#DrillSource>  a d2rq:Database ;
  d2rq:jdbcDSN "jdbc:drill:drillbit=localhost" ;  
  d2rq:jdbcDriver "org.apache.drill.jdbc.Driver" ;
  d2rq:username "" ;
  d2rq:password "" .

<#TriplesMapVerbObject> 
    rml:source <http://example.com/base/#DrillSource> ;
    rml:referenceFormulation rml:SQL2008Query ;
    rml:iterator """
    SELECT 
        t2.id,
        t2.student_name,
        t2.ts,
        t2.instructor_name,
        t2.instructor_id,
        t2.message_id,
        t2.title,
        t2.surveymap.value.`from` AS FromDates
    FROM (
        SELECT 
            t1.flatdata.id AS id,
            t1.flatdata.actor.account.name AS student_name,
            t1.flatdata.`timestamp` AS ts,
            t1.flatdata.context.instructor.name AS instructor_name,
            t1.flatdata.context.instructor.account.name AS instructor_id,
            SPLIT(t1.flatdata.`object`.id, '/')[5] AS message_id,
            t1.flatdata.object.definition.name.`fr-FR` AS title,
            FLATTEN(KVGEN(t1.flatdata.object.definition.extensions)) AS surveymap
        FROM (
            SELECT FLATTEN(statements) AS flatdata
            FROM dfs.statements.`statements18*.json`
        ) t1
        WHERE 
            t1.flatdata.`verb`.id = 'http://activitystrea.ms/schema/1.0/receive'
            AND t1.flatdata.`object`.definition.`type` = 'http://smart.uliege.be/ulla/message'
    ) t2
    """ .

# ===============================
# TriplesMap : Student
# ===============================
<#TriplesMapStudent> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/student/{student_name}" ;
        rml:class ext:Student
    ] ;
    rml:predicateObjectMap [
        rml:predicate foaf:name ;
        rml:objectMap [ rml:reference "student_name" ]
    ] .

# ===============================
# TriplesMap : receive (Activity)
# ===============================
<#TriplesMapReceiveActivity> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/receive/{id}" ;
        rml:class ext:Received
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:startedAtTime ;
        rml:objectMap [ rml:reference "ts" ; rml:datatype xsd:dateTime ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:wasAssociatedWith ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/student/{student_name}" ;
        ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:used ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/message/{message_id}" ;
        ]
    ] .

# ===============================
# TriplesMap : Message (entity)
# ===============================
<#TriplesMapMessage> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/message/{message_id}" ;
        rml:class ext:Message
    ] ;
    rml:predicateObjectMap [
        rml:predicate schema:name ;
        rml:objectMap [ rml:reference "title" ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:generatedAtTime ;
        rml:objectMap [ rml:reference "FromDates" ; rml:datatype xsd:dateTime ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:wasAttributedTo ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/instructor/{instructor_id}" ;
        ]
    ] ;
    rml:predicateObjectMap [
        rml:predicate prov:wasAttributedTo ;
        rml:objectMap [
            rml:template "http://smart.uliege.be/prov-extension/student/{student_name}" ;
        ]
    ] .

# ===============================
# TriplesMap : Instructor   
# ===============================
<#TriplesMapInstructor> a rml:TriplesMap ;
    rml:logicalSource <#TriplesMapVerbObject> ;
    rml:subjectMap [
        rml:template "http://smart.uliege.be/prov-extension/instructor/{instructor_id}" ;
        rml:class ext:Instructor
    ] ;
    rml:predicateObjectMap [
        rml:predicate foaf:name ;
        rml:objectMap [ rml:reference "instructor_name" ]
    ] .
